{
  "name": "@redrixx/writ-react",
  "version": "0.1.1",
  "description": "React bindings for @redrixx/writ — subscribe components as readers. Deliberately thin; the core is fully usable without it.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "NOTICE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test:compat": "node compat/react-smoke.mjs",
    "check:exports": "publint && attw --pack . --profile esm-only",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "hooks",
    "state-management",
    "writ",
    "useSyncExternalStore"
  ],
  "author": "Cody Magnuson (redrixx)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redrix-dev/writ.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/redrix-dev/writ#readme",
  "bugs": {
    "url": "https://github.com/redrix-dev/writ/issues"
  },
  "peerDependencies": {
    "@redrixx/writ": "^0.1.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@redrixx/writ": "*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-test-renderer": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
