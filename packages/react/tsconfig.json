{
  // Editor + typecheck: includes tests, which render into jsdom (needs the DOM
  // lib + node types). The shipped build (tsconfig.build.json) needs neither.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
