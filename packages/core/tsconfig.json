{
  // Editor + typecheck config: sees everything, including tests. Emit is done
  // by tsconfig.build.json (which excludes tests).
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": true,
    // Tests + tooling get Node globals (console, etc.). The shipped build
    // (tsconfig.build.json) keeps `types: []`, so the library itself stays
    // host-agnostic.
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
