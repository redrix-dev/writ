{
  "name": "@redrixx/writ",
  "version": "0.1.0",
  "description": "A substrate-agnostic ownership and lifecycle contract for hot shared state, with separate writer and reader capabilities.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "NOTICE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "check:exports": "publint && attw --pack . --profile esm-only",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "state",
    "state-management",
    "entity",
    "lifecycle",
    "ownership",
    "authority",
    "one-writer",
    "composition-root",
    "typescript"
  ],
  "author": "Cody Magnuson (redrixx)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redrix-dev/writ.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/redrix-dev/writ#readme",
  "bugs": {
    "url": "https://github.com/redrix-dev/writ/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
